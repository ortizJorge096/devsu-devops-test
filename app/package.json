{
  "name": "demo-devops-nodejs",
  "version": "1.0.0",
  "description": "Devsu DevOps technical test - Node.js users API",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix"
  },
  "jest": {
    "transform": {
      "^.+\\.js?$": "babel-jest"
    },
    "collectCoverageFrom": [
      "index.js",
      "users/**/*.js",
      "shared/**/*.js"
    ],
    "coverageReporters": [
      "text",
      "text-summary",
      "lcov",
      "cobertura"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 60,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "author": "Jorge Alexander Caballero Ortiz <jcaballeroo96@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "dotenv": "16.0.3",
    "express": "4.18.2",
    "sequelize": "6.31.0",
    "sqlite3": "5.1.6",
    "yup": "1.0.2"
  },
  "devDependencies": {
    "@babel/preset-env": "7.21.4",
    "@types/express": "4.17.17",
    "babel-jest": "29.5.0",
    "eslint": "8.57.0",
    "jest": "29.5.0",
    "supertest": "6.3.3"
  }
}
